{
  "name": "dcs-control-hub",
  "version": "2.2.0",
  "description": "面向 DCS World 玩家的驱动、工具、插件与本地模组统一管理中心",
  "main": "dist-electron/main.js",
  "author": "DCSHUB",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Jonitane/DCSHUB.git"
  },
  "homepage": "https://github.com/Jonitane/DCSHUB#readme",
  "bugs": {
    "url": "https://github.com/Jonitane/DCSHUB/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:vr-overlay && tsc -b && vite build && electron-builder",
    "build:debug-portable": "npm run build:vr-overlay && tsc -b && vite build && electron-builder --dir",
    "build:vr-overlay": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/build-vr-overlay.ps1",
    "build:web": "tsc -b && vite build",
    "test": "npm run test:dcs-launch && npm run test:mod-manager && npm run test:software-catalog && npm run test:srs && npm run test:i18n && npm run test:update && npm run test:vr-overlay && npm run test:manual-library",
    "test:dcs-launch": "esbuild tests/dcs-launch.integration.ts --bundle --platform=node --format=cjs --outfile=.tmp/dcs-launch.integration.cjs && node .tmp/dcs-launch.integration.cjs",
    "test:mod-manager": "esbuild tests/mod-manager.integration.ts --bundle --platform=node --format=cjs --alias:electron=./tests/electron-stub.ts --outfile=.tmp/mod-manager.integration.cjs && node .tmp/mod-manager.integration.cjs",
    "test:software-catalog": "esbuild tests/software-catalog.integration.ts --bundle --platform=node --format=cjs --outfile=.tmp/software-catalog.integration.cjs && node .tmp/software-catalog.integration.cjs",
    "test:srs": "esbuild tests/srs.integration.ts --bundle --platform=node --format=cjs --outfile=.tmp/srs.integration.cjs && node .tmp/srs.integration.cjs",
    "test:i18n": "esbuild tests/i18n.integration.ts --bundle --platform=node --format=cjs --outfile=.tmp/i18n.integration.cjs && node .tmp/i18n.integration.cjs",
    "test:update": "esbuild tests/update.integration.ts --bundle --platform=node --format=cjs --outfile=.tmp/update.integration.cjs && node .tmp/update.integration.cjs",
    "test:vr-overlay": "npm run build:vr-overlay && esbuild tests/vr-overlay.integration.ts --bundle --platform=node --format=cjs --outfile=.tmp/vr-overlay.integration.cjs && node .tmp/vr-overlay.integration.cjs",
    "test:manual-library": "esbuild tests/manual-library.integration.ts --bundle --platform=node --format=cjs --external:@napi-rs/canvas --outfile=.tmp/manual-library.integration.cjs && node .tmp/manual-library.integration.cjs",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.app.json",
    "lint": "eslint src electron tests vite.config.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "@orama/orama": "^3.1.18",
    "@orama/tokenizers": "^3.1.18",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.2.2",
    "adm-zip": "^0.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-overlay-window": "^4.1.0",
    "framer-motion": "^12.41.0",
    "lucide-react": "0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.2.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "pdf-lib": "^1.17.1",
    "typescript": "~5.5",
    "typescript-eslint": "^8.64.0",
    "vite": "^6",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.dcs.controlhub",
    "productName": "DCSHUB",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "build/native/vr-overlay",
        "to": "vr-overlay",
        "filter": [
          "DcsHubOpenXrLayer.dll",
          "DcsHubVrBridge.exe",
          "DCSHUBManualOverlayLayer.json",
          "THIRD_PARTY_NOTICES.md"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "requireAdministrator",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "differentialPackage": false
    }
  }
}
